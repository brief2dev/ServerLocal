# 🚫 VARIABLES DE ENTORNO

# =========================

.env
.env.*
!.env.example

# =========================

# 🚫 SISTEMA / IDE

# =========================

.DS_Store
Thumbs.db

# VSCode

.vscode/

# JetBrains

.idea/

