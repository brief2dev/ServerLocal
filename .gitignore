# 🚫 BASES DE DATOS

# =========================

infra/**/mysql/
infra/**/postgres/
infra/**/mongo/
infra/**/redis/

# Dumps o backups internos

*.sql
*.dump

# =========================

# 🚫 LOGS

# =========================

*.log
logs/
docker/**/logs/

# =========================

# 🚫 BACKUPS GENERADOS

# =========================

backups/
*.tar.gz

